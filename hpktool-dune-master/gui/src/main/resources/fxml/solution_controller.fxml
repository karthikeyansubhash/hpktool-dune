<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hp.workpath.pkgmgt.util.gui.controllers.SolutionController"
            stylesheets="@default.css">
    <center>
        <ScrollPane fx:id="spBackground"
                    fitToWidth="true"
                    fitToHeight="true">
            <VBox fx:id="vbBackground" styleClass="background">
                <!--Description-->
                <VBox styleClass="vbox-components-top">
                    <VBox styleClass="vbox-component" VBox.vgrow="ALWAYS">
                        <VBox VBox.vgrow="ALWAYS">
                            <HBox styleClass="hbox-line" VBox.vgrow="ALWAYS">
                                <Label HBox.hgrow="ALWAYS" text="%label_page_desc_solution" wrapText="true"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
                <!--Solution Components selector-->
                <VBox styleClass="vbox-components">
                    <TitledPane collapsible="false" text="%label_solution_component" styleClass="titled-pane-hp">
                        <VBox styleClass="vbox-component">
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="ALWAYS" text="%label_solution_component_description"/>
                            </HBox>
                            <GridPane hgap="10" vgap="10">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES"/>
                                    <ColumnConstraints hgrow="SOMETIMES"/>
                                    <ColumnConstraints hgrow="SOMETIMES"/>
                                    <ColumnConstraints hgrow="SOMETIMES"/>
                                    <ColumnConstraints hgrow="SOMETIMES"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                </rowConstraints>
                                <CheckBox fx:id="cbComponentAuthentication" text="%label_authentication"
                                          onAction="#handleAuthenticationCheckBox"
                                          GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <CheckBox fx:id="cbComponentAccessory" text="%label_accessory"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <CheckBox fx:id="cbComponentCopyAgent" text="%label_copy_agent"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <CheckBox fx:id="cbComponentPrintAgent" text="%label_print_agent"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <CheckBox fx:id="cbComponentScanAgent" text="%label_scan_agent"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                                <CheckBox fx:id="cbComponentDeviceUsage" text="%label_device_usage"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <CheckBox fx:id="cbComponentStatistics" text="%label_statistics"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <CheckBox fx:id="cbComponentSupplies" text="%label_supplies"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                <CheckBox fx:id="cbComponentWebService" text="%label_webservice"
                                          onAction="#handleComponentCheckBox"
                                          GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                            </GridPane>
                        </VBox>
                    </TitledPane>
                </VBox>
                <!--Solution Components-->
                <VBox styleClass="vbox-components">
                    <ScrollPane styleClass="tabs">
                        <HBox>
                            <Button fx:id="btSolutionTab"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_solution"
                                    styleClass="button-tab-selected" onAction="#handleComponentButton"/>
                            <Button fx:id="btAccessoryTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_accessory"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btCopyAgentTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_copy_agent"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btPrintAgentTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_print_agent"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btScanAgentTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_scan_agent"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btDeviceUsageTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text='%label_device_usage'
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btStatisticsTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_statistics"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btSuppliesTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_supplies"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btWebServiceTab" visible="false" managed="false"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_webservice"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                            <Button fx:id="btBuildOptionTab"
                                    mnemonicParsing="false" HBox.hgrow="NEVER" text="%label_build_option"
                                    styleClass="button-tab" onAction="#handleComponentButton"/>
                        </HBox>
                    </ScrollPane>
                    <!--Solution Box-->
                    <VBox fx:id="vbSolutionBox" styleClass="vbox-component">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_apk" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionApk" HBox.hgrow="ALWAYS" promptText="%hint_solution_apk"
                                       editable="false"/>
                            <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_select_file"
                                    onAction="#handleSolutionApkSelect"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_config" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionConfig" HBox.hgrow="ALWAYS" promptText="%hint_solution_config"
                                       editable="false"/>
                            <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_clear"
                                    styleClass="button-white" onAction="#handleSolutionConfigClear"/>
                            <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_select_file"
                                    onAction="#handleSolutionConfigSelect"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_id" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionId" HBox.hgrow="ALWAYS" promptText="%hint_uuid"/>
                            <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_generate"
                                    onAction="#handleSolutionIdGenerate"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_name" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionName" HBox.hgrow="ALWAYS" promptText="%hint_solution_name"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_description" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionDescription" HBox.hgrow="ALWAYS"
                                       promptText="%hint_solution_description"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_vendor" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionVendor" HBox.hgrow="ALWAYS" promptText="%hint_solution_vendor"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_version" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionVersion" HBox.hgrow="ALWAYS"
                                       promptText="%hint_solution_version"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_versionNumber" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionVersionNumber" HBox.hgrow="ALWAYS"
                                       promptText="%hint_solution_version_number"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_date" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionDate" HBox.hgrow="ALWAYS" promptText="%hint_date"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_platform_version" styleClass="label-name"/>
                            <ComboBox fx:id="cbSolutionPlatformVersion" HBox.hgrow="NEVER"
                                      onAction="#handlePlatformVersionComboBox"/>
                            <!--Button: connect device?-->
                            <!--Label device version msg-->
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_email" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionEmail" HBox.hgrow="ALWAYS" promptText="%hint_email"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_phone" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionPhone" HBox.hgrow="ALWAYS" promptText="%hint_phone"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_url" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionUrl" HBox.hgrow="ALWAYS" promptText="%hint_url"/>
                        </HBox>
                        <!--application-->
                        <VBox fx:id="vbApplicationBox" styleClass="vbox-component-inner">
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                                <Label HBox.hgrow="NEVER" text="%label_applications" styleClass="label-name"/>
                                <VBox HBox.hgrow="ALWAYS">
                                    <HBox styleClass="hbox-line-inner">
                                        <Pane HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="btApplicationAdd"
                                                mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_add_table"
                                                onAction="#handleApplicationAdd"/>
                                    </HBox>
                                    <HBox styleClass="hbox-line-inner">
                                        <TableView fx:id="tvApplication" HBox.hgrow="ALWAYS">
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                            </columnResizePolicy>
                                            <placeholder>
                                                <Label text="%label_no_application"/>
                                            </placeholder>
                                            <columns>
                                                <TableColumn fx:id="tcApplicationId" text="%table_application_id"
                                                             minWidth="100" maxWidth="300"/>
                                                <TableColumn fx:id="tcApplicationName" text="%table_application_name"
                                                             minWidth="60" maxWidth="300"/>
                                                <TableColumn fx:id="tcApplicationPath" text="%table_application_path"
                                                             minWidth="60"/>
                                                <TableColumn fx:id="tcApplicationType" text="%table_application_type"
                                                             minWidth="60" maxWidth="200"/>
                                                <TableColumn fx:id="tcApplicationDetail" minWidth="30" maxWidth="30"/>
                                                <TableColumn fx:id="tcApplicationDelete" minWidth="30" maxWidth="30"/>
                                            </columns>
                                        </TableView>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </VBox>
                        <!--authentication-->
                        <VBox fx:id="vbAuthenticationBox" styleClass="vbox-component-inner" visible="false"
                              managed="false">
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                                <Label HBox.hgrow="NEVER" text="%label_authentication_id" styleClass="label-name"/>
                                <TextField fx:id="tfAuthenticationId" HBox.hgrow="ALWAYS" promptText="%hint_uuid"/>
                                <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_generate"
                                        onAction="#handleAuthenticationIdGenerate"/>
                            </HBox>
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                                <Label HBox.hgrow="NEVER" text="%label_authentication_name" styleClass="label-name"/>
                                <TextField fx:id="tfAuthenticationName" HBox.hgrow="ALWAYS"
                                           promptText="%hint_authentication_name"/>
                            </HBox>
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                                <Label HBox.hgrow="NEVER" text="%label_authentication_path" styleClass="label-name"/>
                                <TextField fx:id="tfAuthenticationPath" HBox.hgrow="ALWAYS" promptText="%hint_path"/>
                            </HBox>
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                                <Label HBox.hgrow="NEVER" text="%label_authentication_pre_prompt"
                                       styleClass="label-name"/>
                                <CheckBox fx:id="cbAuthenticationPrePrompt" text="%checkbox_enable"/>
                            </HBox>
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                                <Label HBox.hgrow="NEVER" text="%label_authentication_title" styleClass="label-name"/>
                                <TextField fx:id="tfAuthenticationTitle" HBox.hgrow="ALWAYS"
                                           promptText="%hint_localized_string_en_us"/>
                                <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_more"
                                        onAction="#handleAuthenticationTitle"/>
                            </HBox>
                            <HBox styleClass="hbox-line">
                                <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                                <Label HBox.hgrow="NEVER" text="%label_authentication_description"
                                       styleClass="label-name"/>
                                <TextField fx:id="tfAuthenticationDescription" HBox.hgrow="ALWAYS"
                                           promptText="%hint_localized_string_en_us"/>
                                <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_more"
                                        onAction="#handleAuthenticationDescription"/>
                            </HBox>
                        </VBox>
                    </VBox>
                    <!--accessory-->
                    <VBox fx:id="vbAccessoryBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_accessories" styleClass="label-name"/>
                            <VBox HBox.hgrow="ALWAYS">
                                <HBox styleClass="hbox-line-inner">
                                    <Pane HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btAccessoryAdd"
                                            mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_add_table"
                                            onAction="#handleAccessoryAdd"/>
                                </HBox>
                                <HBox styleClass="hbox-line-inner">
                                    <TableView fx:id="tvAccessory" HBox.hgrow="ALWAYS">
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>
                                        <placeholder>
                                            <Label text="%label_no_accessory"/>
                                        </placeholder>
                                        <columns>
                                            <TableColumn fx:id="tcAccessoryType" text="%table_accessory_type"
                                                         minWidth="60" maxWidth="150"/>
                                            <TableColumn fx:id="tcAccessoryVendorId" text="%table_accessory_vendor_id"
                                                         minWidth="60"/>
                                            <TableColumn fx:id="tcAccessoryProductId" text="%table_accessory_product_id"
                                                         minWidth="60"/>
                                            <TableColumn fx:id="tcAccessoryDetail" minWidth="30" maxWidth="30"/>
                                            <TableColumn fx:id="tcAccessoryDelete" minWidth="30" maxWidth="30"/>
                                        </columns>
                                    </TableView>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                    <!--Copy-->
                    <VBox fx:id="vbCopyAgentBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_copy_agent" styleClass="label-name"/>
                            <CheckBox fx:id="cbEnableCopyAgent" text="%checkbox_enable"/>
                        </HBox>
                    </VBox>
                    <!--print-->
                    <VBox fx:id="vbPrintAgentBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_print_agent" styleClass="label-name"/>
                            <CheckBox fx:id="cbEnablePrintAgent" text="%checkbox_enable"/>
                        </HBox>
                    </VBox>
                    <!--scan-->
                    <VBox fx:id="vbScanAgentBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_scan_agent" styleClass="label-name"/>
                            <CheckBox fx:id="cbEnableScanAgent" text="%checkbox_enable"/>
                        </HBox>
                    </VBox>
                    <!--Device Usage-->
                    <VBox fx:id="vbDeviceUsageBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_device_usage" styleClass="label-name"/>
                            <CheckBox fx:id="cbEnableDeviceUsage" text="%checkbox_enable"/>
                        </HBox>
                    </VBox>
                    <!--Statistics-->
                    <VBox fx:id="vbStatisticsBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_statistics" styleClass="label-name"/>
                            <CheckBox fx:id="cbEnableStatistics" text="%checkbox_enable"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_statistics_criticalSolution" styleClass="label-name"/>
                            <CheckBox fx:id="cbEnableStatisticsCriticalSolution" text="%checkbox_enable"/>
                        </HBox>
                    </VBox>
                    <!--Supplies-->
                    <VBox fx:id="vbSuppliesBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_supplies" styleClass="label-name"/>
                            <CheckBox fx:id="cbEnableSupplies" text="%checkbox_enable"/>
                        </HBox>
                    </VBox>
                    <!--webservice-->
                    <VBox fx:id="vbWebServiceBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_webservice_title" styleClass="label-name"/>
                            <TextField fx:id="tfWebServiceTitle" HBox.hgrow="ALWAYS"
                                       promptText="%hint_localized_string_en_us"/>
                            <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_more"
                                    onAction="#handleWebServiceTitle"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_webservice_description"
                                   styleClass="label-name"/>
                            <TextField fx:id="tfWebServiceDescription" HBox.hgrow="ALWAYS"
                                       promptText="%hint_localized_string_en_us"/>
                            <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_more"
                                    onAction="#handleWebServiceDescription"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_endpoints" styleClass="label-name"/>
                            <VBox HBox.hgrow="ALWAYS">
                                <HBox styleClass="hbox-line-inner">
                                    <Pane HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btWebServiceAdd"
                                            mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_add_table"
                                            onAction="#handleWebserviceAdd"/>
                                </HBox>
                                <HBox styleClass="hbox-line-inner">
                                    <TableView fx:id="tvWebservice" HBox.hgrow="ALWAYS">
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>
                                        <placeholder>
                                            <Label text="%label_no_webservice"/>
                                        </placeholder>
                                        <columns>
                                            <TableColumn fx:id="tcWebserviceMethod" text="%table_webservice_method"
                                                         minWidth="60"
                                                         maxWidth="150"/>
                                            <TableColumn fx:id="tcWebserviceCategory"
                                                         text="%table_webservice_category"
                                                         minWidth="60" maxWidth="300"/>
                                            <TableColumn fx:id="tcWebserviceAbsolutePath"
                                                         text="%table_webservice_absolute_path"
                                                         minWidth="60"/>
                                            <TableColumn fx:id="tcWebserviceAuth" text="%table_webservice_auth"
                                                         minWidth="60"
                                                         maxWidth="150"/>
                                            <TableColumn fx:id="tcWebserviceDetail" minWidth="30" maxWidth="30"/>
                                            <TableColumn fx:id="tcWebserviceDelete" minWidth="30" maxWidth="30"/>
                                        </columns>
                                    </TableView>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                    <!-- Build Options -->
                    <VBox fx:id="vbBuildOptionBox" styleClass="vbox-component" visible="false" managed="false">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_bundle_serial_number" styleClass="label-name"/>
                            <TextField fx:id="tfBundleSerial" HBox.hgrow="ALWAYS" promptText="%hint_bundle_serial_number"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_sign_tar" styleClass="label-name"/>
                            <CheckBox fx:id="cbSignTar" text="%checkbox_sign_tar" onAction="#handleSignTarCheckBox"/>
                            <HBox fx:id="hbSignTar" HBox.hgrow="ALWAYS" visible="false" styleClass="hbox-line-center">
                                <TextField fx:id="tfSigningKey" HBox.hgrow="ALWAYS" promptText="%hint_signing_key"
                                           editable="false"/>
                                <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_select_file"
                                        onAction="#handleSigningKeySelect"/>
                            </HBox>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <VBox styleClass="vbox-footer">
            <HBox styleClass="hbox-line">
                <SplitMenuButton fx:id="smbCreate" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_create"
                                 styleClass="split-menu-button-hp"
                                 onAction="#handleSolutionBundleCreate">
                    <items>
                        <MenuItem fx:id="miCreateHpk" mnemonicParsing="false" text="%btn_create_hpk"
                                  onAction="#handleHpkBundleCreate"/>
                    </items>
                </SplitMenuButton>
                <ProgressIndicator fx:id="piProgress" HBox.hgrow="NEVER" visible="false" managed="false"/>
                <Label fx:id="lbSolutionBundleCreateResult" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>

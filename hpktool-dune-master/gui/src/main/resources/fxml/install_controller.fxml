<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hp.workpath.pkgmgt.util.gui.controllers.InstallController"
            stylesheets="@default.css">
    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true">
            <VBox fx:id="vbBackground" styleClass="background">
                <VBox styleClass="vbox-components-top">
                    <VBox styleClass="vbox-component" VBox.vgrow="ALWAYS">
                        <VBox VBox.vgrow="ALWAYS">
                            <HBox styleClass="hbox-line" VBox.vgrow="ALWAYS">
                                <Label HBox.hgrow="ALWAYS" text="%label_page_desc_install" wrapText="true"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
                <VBox styleClass="vbox-components">
                    <VBox styleClass="vbox-component">
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_device_address" styleClass="label-name"/>
                            <TextField fx:id="tfDeviceAddress" HBox.hgrow="ALWAYS" promptText="%hint_ip_address"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_device_password" styleClass="label-name"/>
                            <PasswordField fx:id="pfDevicePassword" HBox.hgrow="ALWAYS"
                                           promptText="%hint_admin_password"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_bundle" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionBundle" HBox.hgrow="ALWAYS" promptText="%hint_solution_bundle"
                                       editable="false"/>
                            <Button mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_select_file"
                                    onAction="#handleSolutionBundleSelect"/>
                        </HBox>
                        <HBox styleClass="hbox-line">
                            <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                            <Label HBox.hgrow="NEVER" text="%label_solution_id" styleClass="label-name"/>
                            <TextField fx:id="tfSolutionId" HBox.hgrow="ALWAYS" promptText="%hint_uuid"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <VBox styleClass="vbox-footer">
            <HBox styleClass="hbox-line">
                <Button fx:id="btInstall" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_install"
                        styleClass="button-main" onAction="#handleSolutionInstall"/>
                <Button fx:id="btUninstall" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_uninstall"
                        styleClass="button-main-alt" onAction="#handleSolutionUninstall"/>
                <ProgressIndicator fx:id="piProgress" HBox.hgrow="NEVER" visible="false" managed="false"/>
                <Label fx:id="lbInstallResult" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>

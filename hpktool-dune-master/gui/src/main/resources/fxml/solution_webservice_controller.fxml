<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hp.workpath.pkgmgt.util.gui.controllers.SolutionWebServiceController"
            stylesheets="@default.css">
    <center>
        <VBox styleClass="background">
            <VBox styleClass="vbox-components-top">
                <VBox styleClass="vbox-component">
                    <HBox styleClass="hbox-line">
                        <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                        <Label HBox.hgrow="NEVER" text="%label_webservice_method" styleClass="label-name"/>
                        <fx:define>
                            <ToggleGroup fx:id="toggleWebServiceMethod"/>
                        </fx:define>
                        <RadioButton fx:id="rbGet" mnemonicParsing="false" text="%radio_webservice_get"
                                     toggleGroup="$toggleWebServiceMethod" selected="true"/>
                        <RadioButton fx:id="rbPut" mnemonicParsing="false" text="%radio_webservice_put"
                                     toggleGroup="$toggleWebServiceMethod"/>
                        <RadioButton fx:id="rbPost" mnemonicParsing="false" text="%radio_webservice_post"
                                     toggleGroup="$toggleWebServiceMethod"/>
                        <RadioButton fx:id="rbDelete" mnemonicParsing="false" text="%radio_webservice_delete"
                                     toggleGroup="$toggleWebServiceMethod"/>
                    </HBox>
                    <HBox styleClass="hbox-line">
                        <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                        <Label HBox.hgrow="NEVER" text="%label_webservice_category" styleClass="label-name"/>
                        <TextField fx:id="tfWebServiceCategory" HBox.hgrow="ALWAYS"
                                   promptText="%hint_webservice_category"/>
                    </HBox>
                    <HBox styleClass="hbox-line">
                        <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                        <Label HBox.hgrow="NEVER" text="%label_webservice_absolute_path" styleClass="label-name"/>
                        <TextField fx:id="tfWebServiceAbsolutePath" HBox.hgrow="ALWAYS"
                                   promptText="%hint_webservice_absolute_path"/>
                    </HBox>
                    <HBox styleClass="hbox-line">
                        <Label HBox.hgrow="NEVER" text="%label_mandatory_mark" styleClass="label-mandatory"/>
                        <Label HBox.hgrow="NEVER" text="%label_webservice_auth_type" styleClass="label-name"/>
                        <fx:define>
                            <ToggleGroup fx:id="toggleWebServiceAuthType"/>
                        </fx:define>
                        <RadioButton fx:id="rbNone" mnemonicParsing="false" text="%radio_webservice_none"
                                     toggleGroup="$toggleWebServiceAuthType" selected="true"/>
                        <RadioButton fx:id="rbXAuth" mnemonicParsing="false" text="%radio_webservice_x_auth"
                                     toggleGroup="$toggleWebServiceAuthType"/>
                        <RadioButton fx:id="rbAdmin" mnemonicParsing="false" text="%radio_webservice_admin"
                                     toggleGroup="$toggleWebServiceAuthType"/>
                    </HBox>
                    <HBox styleClass="hbox-line">
                        <Button fx:id="btAdd" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_add"
                                disable="true" onAction="#handleAddAccessory"/>
                        <Button fx:id="btCancel" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_cancel"
                                styleClass="button-white" onAction="#handleCancelAccessory"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hp.workpath.pkgmgt.util.gui.controllers.RawDataController"
            stylesheets="@default.css">
    <center>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true">
            <VBox styleClass="background">
                <VBox styleClass="vbox-components-top" VBox.vgrow="ALWAYS">
                    <VBox styleClass="vbox-component" VBox.vgrow="ALWAYS">
                        <TextArea fx:id="taData" VBox.vgrow="ALWAYS" editable="false"/>
                        <HBox styleClass="hbox-line" VBox.vgrow="NEVER">
                            <Button fx:id="btClose" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_close"
                                    styleClass="button-white" onAction="#handleClose"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

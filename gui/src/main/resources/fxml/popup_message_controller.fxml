<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hp.workpath.pkgmgt.util.gui.controllers.PopupMessageController"
            stylesheets="@default.css">
    <center>
        <VBox styleClass="background" minWidth="500">
            <VBox styleClass="vbox-components-top">
                <VBox styleClass="vbox-component">
                    <HBox styleClass="hbox-line">
                        <ImageView fx:id="ivIcon" fitWidth="48" fitHeight="48"/>
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="lbTitle" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lbContext" HBox.hgrow="ALWAYS"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="hbox-line-center">
                        <Button fx:id="btOk" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_ok"
                                onAction="#handleOk"/>
                        <Button fx:id="btCancel" mnemonicParsing="false" HBox.hgrow="NEVER" text="%btn_cancel"
                                styleClass="button-white" onAction="#handleCancel"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
